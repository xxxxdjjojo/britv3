# ============================================
# TrueDeed Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Supabase (https://supabase.com/dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Reauth token HMAC secret (32+ bytes hex). Generate with: openssl rand -hex 32
# Required in production. Falls back to SUPABASE_SERVICE_ROLE_KEY if not set.
REAUTH_HMAC_SECRET=

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Enable Stripe Connect provider payments (set false to hide payments pages during rollout)
FEATURE_STRIPE_CONNECT_ENABLED=true

# --- Anthropic / Claude AI (https://console.anthropic.com/settings/keys) ---
ANTHROPIC_API_KEY=

# --- MapTiler (https://cloud.maptiler.com/account/keys) ---
NEXT_PUBLIC_MAPTILER_API_KEY=

# --- Resend - Email (https://resend.com/api-keys) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=hello@truedeed.co.uk
RESEND_FROM_NAME=TrueDeed
# Svix signing secret for the Resend events webhook (/api/webhooks/resend)
RESEND_WEBHOOK_SECRET=
# Recipient for the daily Truedeed ledger hash-anchor email (cron skips if unset)
LEDGER_ANCHOR_EMAIL=

# --- HelloSign / Dropbox Sign - E-Signatures ---
# DEPRECATED: e-signature dropped (cost). Not wired in code; leave unset.
# HELLOSIGN_API_KEY=

# --- Companies House - Business Verification (https://developer.company-information.service.gov.uk) ---
# Free, instant key. Used to gate agent/provider onboarding to companies
# registered >= 2 years. Set to "disabled" to bypass the gate.
COMPANIES_HOUSE_API_KEY=

# EPC data is loaded from the bulk dataset into the DB (epc_certificates) and
# linked to properties — there is NO live EPC API key. See docs/epc-dataset.md.

# --- Tenant Referencing / Credit Checks (pluggable provider) ---
# "mock" = no live vendor (cost-neutral default). A real provider (e.g. goodlord,
# homelet) drops in via the referencing adapter; charge the per-check fee to the
# applicant through the existing Stripe account when activated.
REFERENCING_PROVIDER=mock
REFERENCING_API_KEY=
# HMAC secret used to verify inbound referencing webhooks (/api/webhooks/referencing)
REFERENCING_WEBHOOK_SECRET=

# --- Identity Verification / KYC (scaffold; no live vendor) ---
# "stub" = no live vendor. Recommended live option: "stripe" (Stripe Identity,
# reuses the existing Stripe account); "didit" is the cheaper alternative.
KYC_PROVIDER=stub
KYC_API_KEY=

# --- Address / Postcode Resolution (pluggable provider) ---
# "postcode" = free postcodes.io (cost-neutral default; stores only postcode + typed label).
# "os_places" = Ordnance Survey Places / PAF (stub today; requires OS_PLACES_API_KEY when wired).
ADDRESS_PROVIDER=postcode
OS_PLACES_API_KEY=

# --- PlanIt - Planning Applications (https://www.planit.org.uk/api/) ---
# No key required (free public API). Set to "disabled" to turn off the
# planning applications section on property pages.
# PLANIT_API_KEY=

# --- Inngest - Background Jobs (https://app.inngest.com) ---
# Required in production. Get from Inngest dashboard > Manage > Signing Key.
INNGEST_SIGNING_KEY=

# --- Upstash Redis - Rate Limiting & Caching (https://console.upstash.com) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry - Error Tracking (https://sentry.io/settings/account/api/auth-tokens) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog - Analytics (https://app.posthog.com/project/settings) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3004
NODE_ENV=development

# Unsubscribe token HMAC secret (32+ bytes hex). Generate with: openssl rand -hex 32
# Required in production. Falls back to SUPABASE_SERVICE_ROLE_KEY in dev only.
UNSUBSCRIBE_TOKEN_SECRET=

# Quote signing — generate with: openssl rand -hex 32
QUOTE_SIGNING_SECRET=your-32-byte-hex-secret-here

# Billing replay HMAC secret (32+ bytes hex). Used by the admin replay endpoint
# (POST /api/admin/billing/replay/:event_id) to verify x-replay-signature.
# Generate with: openssl rand -hex 32
REPLAY_SIGNING_SECRET=

# ============================================
# Memo Pivot v2 — Stripe Prices (run scripts/stripe-setup/create-pricing-v2.ts)
# ============================================
# Provision real IDs with:
#   node --experimental-strip-types scripts/stripe-setup/create-pricing-v2.ts
# then `cat .env.pricing-v2.generated >> .env.local`.

# Sellers (one-off; no annual)
STRIPE_SELLER_BASIC_PRICE_ID=
STRIPE_SELLER_PLUS_PRICE_ID=
STRIPE_SELLER_PREMIUM_PRICE_ID=

# Agents (subscription)
STRIPE_AGENT_PRO_PRICE_ID=
STRIPE_AGENT_PRO_ANNUAL_PRICE_ID=
STRIPE_AGENT_ELITE_PRICE_ID=
STRIPE_AGENT_ELITE_ANNUAL_PRICE_ID=

# Landlords (subscription)
STRIPE_LANDLORD_ESSENTIAL_PRICE_ID=
STRIPE_LANDLORD_ESSENTIAL_ANNUAL_PRICE_ID=
STRIPE_LANDLORD_PRO_PRICE_ID=
STRIPE_LANDLORD_PRO_ANNUAL_PRICE_ID=
STRIPE_LANDLORD_PORTFOLIO_PRICE_ID=
STRIPE_LANDLORD_PORTFOLIO_ANNUAL_PRICE_ID=

# Providers (subscription)
STRIPE_PROVIDER_PRO_PRICE_ID=
STRIPE_PROVIDER_PRO_ANNUAL_PRICE_ID=
STRIPE_PROVIDER_ELITE_PRICE_ID=
STRIPE_PROVIDER_ELITE_ANNUAL_PRICE_ID=

# Providers niche (subscription)
STRIPE_PROVIDER_CONVEYANCER_PRICE_ID=
STRIPE_PROVIDER_CONVEYANCER_ANNUAL_PRICE_ID=
STRIPE_PROVIDER_SURVEYOR_PRICE_ID=
STRIPE_PROVIDER_SURVEYOR_ANNUAL_PRICE_ID=
STRIPE_PROVIDER_MORTGAGE_BROKER_PRICE_ID=
STRIPE_PROVIDER_MORTGAGE_BROKER_ANNUAL_PRICE_ID=

# Developers (subscription)
STRIPE_DEVELOPER_SINGLE_PRICE_ID=
STRIPE_DEVELOPER_SINGLE_ANNUAL_PRICE_ID=
STRIPE_DEVELOPER_MULTI_PRICE_ID=
STRIPE_DEVELOPER_MULTI_ANNUAL_PRICE_ID=
STRIPE_DEVELOPER_ENTERPRISE_PRICE_ID=
STRIPE_DEVELOPER_ENTERPRISE_ANNUAL_PRICE_ID=

# Traders (subscription)
STRIPE_TRADER_PRO_PRICE_ID=
STRIPE_TRADER_PRO_ANNUAL_PRICE_ID=
STRIPE_TRADER_ELITE_PRICE_ID=
STRIPE_TRADER_ELITE_ANNUAL_PRICE_ID=

# Boosts (one-off)
STRIPE_BOOST_7D_PRICE_ID=
STRIPE_BOOST_14D_PRICE_ID=
STRIPE_BOOST_30D_PRICE_ID=
STRIPE_BOOST_AI_VALUATION_PRICE_ID=
STRIPE_BOOST_STORY_PRICE_ID=
STRIPE_BOOST_DIGEST_PRICE_ID=

# --- GoCardless - Truedeed Bacs Direct Debit billing (https://manage.gocardless.com) ---
# Access token for the GoCardless API; billing is disabled when unset.
GOCARDLESS_ACCESS_TOKEN=
# Webhook endpoint secret for /api/webhooks/gocardless signature verification.
GOCARDLESS_WEBHOOK_SECRET=
# "sandbox" (default) or "live".
GOCARDLESS_ENVIRONMENT=sandbox
