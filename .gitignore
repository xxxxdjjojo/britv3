# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# playwright auth state
e2e/.auth/

# playwright test artifacts
test-results/
playwright-report/

# git worktrees
.worktrees/

# .gstack/ is tracked except for secrets
.gstack/secrets/
.gstack/.env.local
.gstack/cache/

# supabase local dev temp files (may contain credentials)
supabase/.temp/

# Land Registry ingest checkpoint (transient, holds chunk progress)
.ingest-land-registry-state.json

# Codex local config (contains API keys — never commit)
.codex/
